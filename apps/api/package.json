{
  "name": "@sidewalk/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "dotenv -e .env.test -- prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "dotenv -e .env.test -- prisma generate && tsc -p tsconfig.json --noEmit",
    "pretest": "dotenv -e .env.test -- prisma generate && dotenv -e .env.test -- prisma db push --force-reset --skip-generate",
    "test": "dotenv -e .env.test -- vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sidewalk/shared": "workspace:*",
    "bcryptjs": "2.4.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/supertest": "6.0.3",
    "@vitest/coverage-v8": "3.2.2",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0",
    "supertest": "7.1.0",
    "tsx": "^4.19.4",
    "vitest": "3.2.2"
  }
}

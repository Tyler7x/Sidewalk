{
  "name": "@sidewalk/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sidewalk/config": "workspace:*",
    "@sidewalk/types": "workspace:*",
    "bcryptjs": "2.4.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/morgan": "^1.9.10",
    "@types/supertest": "6.0.3",
    "@vitest/coverage-v8": "3.2.2",
    "supertest": "7.1.0",
    "tsx": "^4.19.4",
    "vitest": "3.2.2"
  }
}
